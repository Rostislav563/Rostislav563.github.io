<article class="cat-card">
    <div class="card-image">
        <img src="<%= cat.image.url %>" alt="<%= cat.name %>" loading="lazy">
    </div>
    <div class="card-content">
        <h2><%= cat.name %></h2>
        
        <% if (cat.origin) { %>
            <p class="origin">📍 <%= cat.origin %></p>
        <% } %>
        
        <% if (cat.temperament) { %>
            <p class="temperament"><%= cat.temperament %></p>
        <% } %>
        
        <% if (cat.description) { %>
            <p class="description"><%= cat.description.substring(0, 150) %><%= cat.description.length > 150 ? '...' : '' %></p>
        <% } %>
        
        <div class="stats">
            <% if (cat.life_span) { %>
                <span class="stat">🕐 <%= cat.life_span %> years</span>
            <% } %>
            <% if (cat.weight && cat.weight.metric) { %>
                <span class="stat">⚖️ <%= cat.weight.metric %> kg</span>
            <% } %>
        </div>
    </div>
</article>
